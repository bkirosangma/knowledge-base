# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# editors
.vscode/
.idea/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# git worktrees (local development isolation)
.worktrees/

# typescript
*.tsbuildinfo
next-env.d.ts

# python (skills/knowledge-base/scripts uses pytest; no value in tracking byte-cache)
**/__pycache__/
*.pyc
.pytest_cache/

src/app/architecture_designer/data
src/app/knowledge_base/data
src/app/knowledge_base/infrastructure/__scratch__/
graphify-out

